@inherits LayoutComponentBase
@using MES.Blazor.Models
@using MES.Blazor.Services
@using MudBlazor
@inject IAuthService AuthService
@inject NavigationManager Navigation

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ms-2">不锈钢无缝钢管 MES 系统</MudText>
        <MudSpacer />
        
        <MudMenu Icon="@Icons.Material.Filled.Person" Label="@(_currentUser?.Username ?? "用户")">
            <MudMenuItem OnClick="OnLogoutClick">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="me-2" />
                <MudText>退出登录</MudText>
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Mini" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                仪表板
            </MudNavLink>

            <MudNavGroup Title="订单管理" Icon="@Icons.Material.Filled.ShoppingCart" Expanded="true">
                <MudNavLink Href="/orders" Icon="@Icons.Material.Filled.Receipt">销售订单</MudNavLink>
                <MudNavLink Href="/customers" Icon="@Icons.Material.Filled.People">客户档案</MudNavLink>
                <MudNavLink Href="/standards" Icon="@Icons.Material.Filled.Description">生产标准</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="工单管理" Icon="@Icons.Material.Filled.Assignment">
                <MudNavLink Href="/workorders" Icon="@Icons.Material.Filled.ListAlt">生产工单</MudNavLink>
                <MudNavLink Href="/stock-production" Icon="@Icons.Material.Filled.Inventory">库料改制</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="批次管理" Icon="@Icons.Material.Filled.QrCodeScanner">
                <MudNavLink Href="/batches" Icon="@Icons.Material.Filled.QrCode">生产批次</MudNavLink>
                <MudNavLink Href="/process-records" Icon="@Icons.Material.Filled.History">工序记录</MudNavLink>
                <MudNavLink Href="/mobile-report" Icon="@Icons.Material.Filled.QrCodeScanner">扫码报工</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="质量管理" Icon="@Icons.Material.Filled.Verified">
                <MudNavLink Href="/inspections" Icon="@Icons.Material.Filled.Science">检验记录</MudNavLink>
                <MudNavLink Href="/certificates" Icon="@Icons.Material.Filled.Description">质量保证书</MudNavLink>
                <MudNavLink Href="/nonconformance" Icon="@Icons.Material.Filled.Warning">不合格登记</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="设备管理" Icon="@Icons.Material.Filled.PrecisionManufacturing">
                <MudNavLink Href="/equipment" Icon="@Icons.Material.Filled.Devices">设备清单</MudNavLink>
                <MudNavLink Href="/maintenance" Icon="@Icons.Material.Filled.Build">保养计划</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="仓库管理" Icon="@Icons.Material.Filled.Warehouse">
                <MudNavLink Href="/inventory" Icon="@Icons.Material.Filled.Inventory">库存查询</MudNavLink>
                <MudNavLink Href="/transactions" Icon="@Icons.Material.Filled.SwapHoriz">出入库记录</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="物料管理" Icon="@Icons.Material.Filled.Category">
                <MudNavLink Href="/materials" Icon="@Icons.Material.Filled.Category">物料档案</MudNavLink>
                <MudNavLink Href="/suppliers" Icon="@Icons.Material.Filled.LocalShipping">供应商</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="报表中心" Icon="@Icons.Material.Filled.Analytics">
                <MudNavLink Href="/reports/production" Icon="@Icons.Material.Filled.ShowChart">生产报表</MudNavLink>
                <MudNavLink Href="/reports/quality" Icon="@Icons.Material.Filled.Verified">质量报表</MudNavLink>
                <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">生产看板</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private UserInfo? _currentUser;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task OnLogoutClick()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }
}
