@page "/test-simple"
@using MES.Blazor.Shared
@layout EmptyLayout

<h1 style="color: green;">Simple Test Page</h1>

<div style="margin: 20px; padding: 20px; border: 2px solid #ccc;">
    <h3>Blazor Functionality Test</h3>
    <p>Counter: @count</p>
    <button @onclick="IncrementCount" style="padding: 10px 20px; background: blue; color: white; border: none; cursor: pointer;">
        Click to Increase Count
    </button>

    <div style="margin-top: 20px;">
        <p>Input Test: @inputValue</p>
        <input @bind="inputValue" @bind:event="oninput" style="padding: 8px; width: 200px;" />
    </div>
</div>

<div style="margin-top: 20px; padding: 10px; background: lightyellow; border: 1px solid orange;">
    <h3>Diagnostic Information</h3>
    <p><strong>Checklist:</strong></p>
    <ul>
        <li>Can see this page = Blazor basic functionality works</li>
        <li>Button click increases count = onclick binding works</li>
        <li>Input box accepts text = Two-way binding works</li>
    </ul>
</div>

@code {
    private int count = 0;
    private string inputValue = string.Empty;

    private void IncrementCount()
    {
        count++;
        Console.WriteLine($"[TEST] Count increased to: {count}");
    }
}
