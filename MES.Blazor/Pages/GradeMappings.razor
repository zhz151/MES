@page "/grade-mappings"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Models
@using Microsoft.AspNetCore.Authorization
@inject GradeMappingService GradeMappingService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@attribute [Authorize(Roles = "OrderStaff,OrderDirector,Admin")]

<div class="mt-4">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Class="font-weight-bold">
                    <MudIcon Icon="@Icons.Material.Filled.Science" Class="mr-2" Color="Color.Primary" />
                    牌号对照管理
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">标准牌号 ↔ 工厂牌号 映射配置</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NavigateToCreate">
                    新建牌号
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent>
            <!-- 搜索栏 -->
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudTextField T="string"
                                  Label="模糊搜索 - 标准牌号/工厂牌号"
                                  Placeholder="输入关键字进行模糊搜索..."
                                  @bind-Value="searchKeyword"
                                  Immediate="true"
                                  DebounceInterval="500"
                                  OnKeyDown="OnSearchKeyDown"
                                  Clearable="true"
                                  ClearButton="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="Search">
                        搜索
                    </MudButton>
                </MudItem>
            </MudGrid>

            <MudTable @ref="table"
                      T="StandardGradeMappingDto"
                      ServerData="OnServerData"
                      Loading="@isLoading"
                      Dense="true"
                      Hover="true"
                      Class="mt-4"
                      Elevation="0"
                      RowsPerPageLabel="每页行数:">
                <ToolBarContent>
                    <MudText Typo="Typo.body2" Class="ml-auto">
                        共 @totalCount 条记录
                    </MudText>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>标准牌号</MudTh>
                    <MudTh>工厂牌号</MudTh>
                    <MudTh>密度(g/cm³)</MudTh>
                    <MudTh>热处理工艺</MudTh>
                    <MudTh>特殊材料</MudTh>
                    <MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.StandardGrade</MudTd>
                    <MudTd>@context.PlantGrade</MudTd>
                    <MudTd>@context.Density.ToString("F4")</MudTd>
                    <MudTd>@context.HeatTreatment</MudTd>
                    <MudTd>
                        <MudChip Size="Size.Small" Color="@(context.SpecialMaterial? Color.Warning: Color.Default)">
                            @(context.SpecialMaterial ? "特殊" : "常规")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="() => ViewGradeMapping(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="() => EditGradeMapping(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => DeleteGradeMapping(context)" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
</div>

@code {
    private MudTable<StandardGradeMappingDto>? table;
    private List<StandardGradeMappingDto> gradeMappings = new();
    private bool isLoading = false;
    private string searchKeyword = string.Empty;
    private int totalCount = 0;

    private async Task<TableData<StandardGradeMappingDto>> OnServerData(TableState state)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var queryParams = new QueryParams
            {
                PageIndex = state.Page + 1,
                PageSize = state.PageSize,
                Keyword = string.IsNullOrWhiteSpace(searchKeyword) ? null : searchKeyword
            };

            var result = await GradeMappingService.GetPagedAsync(queryParams);

            if (result.Success && result.Data != null)
            {
                gradeMappings = result.Data.Items;
                totalCount = result.Data.TotalCount;
                return new TableData<StandardGradeMappingDto>
                {
                    Items = gradeMappings,
                    TotalItems = totalCount
                };
            }
            
            return new TableData<StandardGradeMappingDto>
            {
                Items = new List<StandardGradeMappingDto>(),
                TotalItems = 0
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载失败: {ex.Message}");
            Snackbar.Add($"加载失败: {ex.Message}", Severity.Error);
            return new TableData<StandardGradeMappingDto>
            {
                Items = new List<StandardGradeMappingDto>(),
                TotalItems = 0
            };
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task Search()
    {
        if (table != null)
        {
            await table.ReloadServerData();
        }
    }

    private void OnSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            _ = Search();
        }
    }

    private void NavigateToCreate() => Navigation.NavigateTo("/grade-mappings/create");
    private void ViewGradeMapping(int id) => Navigation.NavigateTo($"/grade-mappings/{id}");
    private void EditGradeMapping(int id) => Navigation.NavigateTo($"/grade-mappings/{id}/edit");

    private async Task DeleteGradeMapping(StandardGradeMappingDto mapping)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"确定要删除牌号对照 \"{mapping.StandardGrade}\" 吗？\n\n如果该牌号已被订单使用，删除后可能导致数据问题！");

        if (confirmed)
        {
            try
            {
                var result = await GradeMappingService.DeleteAsync(mapping.Id);
                if (result.Success)
                {
                    Snackbar.Add("删除成功", Severity.Success);
                    await Search();
                }
                else
                {
                    Snackbar.Add(result.Message ?? "删除失败", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
            }
        }
    }
}