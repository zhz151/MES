@page "/customers"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Models
@using MES.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject CustomerService CustomerService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@attribute [Authorize(Roles = "OrderStaff,OrderDirector,Admin")]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Class="font-weight-bold">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" Color="Color.Primary" />
                    客户管理
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">客户档案信息</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NavigateToCreate">
                    新建客户
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent>
            <!-- 搜索栏 -->
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudTextField T="string"
                                  Label="模糊搜索 - 客户编码/单位/业务员"
                                  Placeholder="输入关键字进行模糊搜索..."
                                  @bind-Value="searchKeyword"
                                  Immediate="true"
                                  DebounceInterval="500"
                                  OnKeyDown="OnSearchKeyDown"
                                  Clearable="true"
                                  ClearButton="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="Search">
                        搜索
                    </MudButton>
                </MudItem>
            </MudGrid>

            <!-- 数据表格 -->
            <MudTable T="CustomerProfileDto"
                      Items="@customers"
                      TotalItems="@totalCount"
                      Loading="@isLoading"
                      Dense="true"
                      Hover="true"
                      Class="mt-4"
                      Elevation="0"
                      @bind-CurrentPage="currentPage"
                      @bind-RowsPerPage="pageSize"
                      RowsPerPageLabel="每页行数:"
                      OnPageChanged="OnPageChanged"
                      OnRowsPerPageChanged="OnPageSizeChanged">
                <ToolBarContent>
                    <MudText Typo="Typo.body2" Class="ml-auto">
                        共 @totalCount 条记录
                    </MudText>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>客户编码</MudTh>
                    <MudTh>客户单位</MudTh>
                    <MudTh>业务员</MudTh>
                    <MudTh>联系人</MudTh>
                    <MudTh>联系电话</MudTh>
                    <MudTh>状态</MudTh>
                    <MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.CustomerCode</MudTd>
                    <MudTd>@context.CustomerUnit</MudTd>
                    <MudTd>@context.Salesman</MudTd>
                    <MudTd>@context.ContactPerson</MudTd>
                    <MudTd>@context.ContactPhone</MudTd>
                    <MudTd>
                        <MudChip Size="Size.Small" Color="@(context.Status == CustomerStatus.Active ? Color.Success : Color.Error)">
                            @(context.Status == CustomerStatus.Active ? "启用" : "停用")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="() => ViewCustomer(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="() => EditCustomer(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => DeleteCustomer(context)" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private List<CustomerProfileDto> customers = new();
    private bool isLoading = true;
    private string searchKeyword = string.Empty;
    
    // 分页相关
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var queryParams = new QueryParams
            {
                PageIndex = currentPage,
                PageSize = pageSize,
                Keyword = string.IsNullOrWhiteSpace(searchKeyword) ? null : searchKeyword
            };

            var result = await CustomerService.GetPagedAsync(queryParams);
            
            if (result.Success && result.Data != null)
            {
                customers = result.Data.Items;
                totalCount = result.Data.TotalCount;
                Console.WriteLine($"加载成功: 第{currentPage}页, {customers.Count}条, 总数: {totalCount}");
            }
            else
            {
                customers = new List<CustomerProfileDto>();
                totalCount = 0;
                Snackbar.Add(result?.Message ?? "加载失败", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载失败: {ex.Message}");
            Snackbar.Add($"加载失败: {ex.Message}", Severity.Error);
            customers = new List<CustomerProfileDto>();
            totalCount = 0;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task Search()
    {
        currentPage = 1;
        await LoadData();
        
        if (!string.IsNullOrEmpty(searchKeyword))
        {
            Snackbar.Add($"搜索关键字: {searchKeyword}, 找到 {totalCount} 条记录", Severity.Info);
        }
    }

    private void OnSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            _ = Search();
        }
    }

    private async Task OnPageChanged(int page)
    {
        if (currentPage != page)
        {
            currentPage = page;
            await LoadData();
        }
    }

    private async Task OnPageSizeChanged(int size)
    {
        if (pageSize != size)
        {
            pageSize = size;
            currentPage = 1;
            await LoadData();
        }
    }

    private void NavigateToCreate() => Navigation.NavigateTo("/customers/create");
    private void ViewCustomer(int id) => Navigation.NavigateTo($"/customers/{id}");
    private void EditCustomer(int id) => Navigation.NavigateTo($"/customers/{id}/edit");

    private async Task DeleteCustomer(CustomerProfileDto customer)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"确定要删除客户 \"{customer.CustomerUnit}\" 吗？\n\n删除后数据将不可恢复！");

        if (confirmed)
        {
            try
            {
                var result = await CustomerService.DeleteAsync(customer.Id);
                if (result.Success)
                {
                    Snackbar.Add("删除成功", Severity.Success);
                    await LoadData();
                }
                else
                {
                    Snackbar.Add(result.Message ?? "删除失败", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
            }
        }
    }
}