@page "/orders/create"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Models
@using MES.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject IOrderService OrderService
@inject ICustomerService CustomerService
@inject IProductionStandardService StandardService
@inject IGradeMappingService GradeMappingService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "OrderDirector,Admin")]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Class="font-weight-bold">
                    新建订单
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">创建新的销售订单</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Text" OnClick="GoBack">返回</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitOrder" Disabled="@isSubmitting">
                    提交订单
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent>
            <!-- 订单基本信息 -->
            <MudText Typo="Typo.subtitle1" Class="mb-3">基本信息</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="orderNumber"
                                  Label="订单号"
                                  Variant="Variant.Outlined"
                                  HelperText="请输入11位订单号"
                                  Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="signDate"
                                   Label="签订日期"
                                   Variant="Variant.Outlined"
                                   Required="true" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudSelect T="int" @bind-Value="selectedCustomerId"
                               Label="客户单位"
                               Variant="Variant.Outlined"
                               Required="true">
                        @foreach (var customer in customers)
                        {
                            <MudSelectItem Value="@customer.Id">@customer.CustomerUnit</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            <!-- 订单项次 -->
            <MudText Typo="Typo.subtitle1" Class="mb-3">订单项次</MudText>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddOrderItem"
                       Class="mb-3">
                添加项次
            </MudButton>

            @if (orderItemViewModels.Count == 0)
            {
                <MudAlert Severity="Severity.Info">请点击上方按钮添加订单项次</MudAlert>
            }
            else
            {
                @for (int i = 0; i < orderItemViewModels.Count; i++)
                {
                    var vm = orderItemViewModels[i];
                    var index = i;
                    <MudCard Class="mb-4" Variant="Variant.Outlined">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">项次 @(i + 1)</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="() => RemoveOrderItem(index)" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <!-- 交货日期 -->
                                <MudItem xs="12" md="6">
                                    <MudDatePicker @bind-Date="vm.DeliveryDate"
                                                   Label="交货日期"
                                                   Variant="Variant.Outlined"
                                                   Required="true" />
                                </MudItem>

                                <!-- 结算方式 -->
                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" @bind-Value="vm.SettlementMethod"
                                               Label="结算方式"
                                               Variant="Variant.Outlined"
                                               Required="true">
                                        <MudSelectItem Value="@("Theoretical")">理算</MudSelectItem>
                                        <MudSelectItem Value="@("Weighing")">过磅</MudSelectItem>
                                        <MudSelectItem Value="@("WeighingNegative")">过磅-负</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- 物料名称 -->
                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" @bind-Value="vm.MaterialName"
                                               Label="物料名称"
                                               Variant="Variant.Outlined"
                                               Required="true">
                                        <MudSelectItem Value="@("SeamlessPipe")">无缝管</MudSelectItem>
                                        <MudSelectItem Value="@("WeldedPipe")">焊管</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- 产品标准 -->
                                <MudItem xs="12" md="6">
                                    <MudSelect T="int" @bind-Value="vm.ProductionStandardId"
                                               Label="产品标准"
                                               Variant="Variant.Outlined"
                                               Required="true">
                                        @foreach (var std in productionStandards)
                                        {
                                            <MudSelectItem Value="@std.Id">@std.StandardCode</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <!-- 交货状态 -->
                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" @bind-Value="vm.DeliveryState"
                                               Label="交货状态"
                                               Variant="Variant.Outlined"
                                               Required="true">
                                        <MudSelectItem Value="@("SolutionAnnealedAndPickled")">固溶酸洗</MudSelectItem>
                                        <MudSelectItem Value="@("Bright")">光亮</MudSelectItem>
                                        <MudSelectItem Value="@("Hard")">硬态</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- 标准牌号 -->
                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" @bind-Value="vm.StandardGrade"
                                               Label="标准牌号"
                                               Variant="Variant.Outlined"
                                               Required="true">
                                        @foreach (var grade in gradeMappings)
                                        {
                                            <MudSelectItem Value="@grade.StandardGrade">@grade.StandardGrade</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <!-- 外径 -->
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="decimal" @bind-Value="vm.OuterDiameter"
                                                     Label="外径"
                                                     Variant="Variant.Outlined"
                                                     Format="F3"
                                                     Required="true" />
                                </MudItem>

                                <!-- 壁厚 -->
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="decimal" @bind-Value="vm.WallThickness"
                                                     Label="壁厚"
                                                     Variant="Variant.Outlined"
                                                     Format="F3"
                                                     Required="true" />
                                </MudItem>

                                <!-- 合同重量 -->
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="decimal" @bind-Value="vm.ContractWeight"
                                                     Label="合同重量(kg)"
                                                     Variant="Variant.Outlined"
                                                     Format="F3"
                                                     Required="true" />
                                </MudItem>

                                <!-- 长度状态 -->
                                <MudItem xs="12" md="4">
                                    <MudSelect T="string" @bind-Value="vm.LengthStatus"
                                               Label="长度状态"
                                               Variant="Variant.Outlined"
                                               Required="true">
                                        <MudSelectItem Value="@("Fixed")">定尺</MudSelectItem>
                                        <MudSelectItem Value="@("Range")">范围尺</MudSelectItem>
                                        <MudSelectItem Value="@("NonFixed")">非定尺</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <!-- 根据长度状态显示不同字段 -->
                                @if (vm.LengthStatus == "Fixed")
                                {
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="decimal?" @bind-Value="vm.MinLength"
                                                         Label="长度(mm)"
                                                         Variant="Variant.Outlined"
                                                         Format="F0"
                                                         Required="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="int?" @bind-Value="vm.Quantity"
                                                         Label="支数"
                                                         Variant="Variant.Outlined"
                                                         Format="F0" />
                                    </MudItem>
                                }
                                else if (vm.LengthStatus == "Range")
                                {
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="decimal?" @bind-Value="vm.MinLength"
                                                         Label="最小长度(mm)"
                                                         Variant="Variant.Outlined"
                                                         Format="F0"
                                                         Required="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="decimal?" @bind-Value="vm.MaxLength"
                                                         Label="最大长度(mm)"
                                                         Variant="Variant.Outlined"
                                                         Format="F0"
                                                         Required="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="decimal?" @bind-Value="vm.Meters"
                                                         Label="米数(m)"
                                                         Variant="Variant.Outlined"
                                                         Format="F2" />
                                    </MudItem>
                                }
                                else if (vm.LengthStatus == "NonFixed")
                                {
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="decimal?" @bind-Value="vm.Meters"
                                                         Label="米数(m)"
                                                         Variant="Variant.Outlined"
                                                         Format="F2" />
                                    </MudItem>
                                }

                                <!-- 备注 -->
                                <MudItem xs="12" md="12">
                                    <MudTextField @bind-Value="vm.Remark"
                                                  Label="备注"
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                }
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    // 订单项次 ViewModel
    private class OrderItemViewModel
    {
        public DateTime? DeliveryDate { get; set; }
        public string SettlementMethod { get; set; } = string.Empty;
        public string MaterialName { get; set; } = string.Empty;
        public int ProductionStandardId { get; set; }
        public string DeliveryState { get; set; } = string.Empty;
        public string StandardGrade { get; set; } = string.Empty;
        public decimal OuterDiameter { get; set; }
        public decimal WallThickness { get; set; }
        public decimal ContractWeight { get; set; }
        public string LengthStatus { get; set; } = string.Empty;
        public decimal? MinLength { get; set; }
        public decimal? MaxLength { get; set; }
        public int? Quantity { get; set; }
        public decimal? Meters { get; set; }
        public string? Remark { get; set; }
    }

    // 订单基本信息
    private string orderNumber = string.Empty;
    private DateTime? signDate = DateTime.Today;
    private int selectedCustomerId;

    // 订单项次 ViewModel 列表
    private List<OrderItemViewModel> orderItemViewModels = new();

    // 下拉框数据
    private List<CustomerProfileDto> customers = new();
    private List<ProductionStandardDto> productionStandards = new();
    private List<StandardGradeMappingDto> gradeMappings = new();

    private bool isSubmitting;

    protected override async Task OnInitializedAsync()
    {
        await LoadDropdownData();
    }

    private async Task LoadDropdownData()
    {
        var customersResult = await CustomerService.GetPagedAsync(new QueryParams { PageSize = 999 });
        if (customersResult.Success && customersResult.Data != null)
        {
            customers = customersResult.Data.Items;
        }

        productionStandards = await StandardService.GetAllAsync();
        gradeMappings = await GradeMappingService.GetAllAsync();
        StateHasChanged();
    }

    private void AddOrderItem()
    {
        orderItemViewModels.Add(new OrderItemViewModel
        {
            DeliveryDate = DateTime.Now.AddMonths(1),
            SettlementMethod = "Theoretical",
            MaterialName = "SeamlessPipe",
            DeliveryState = "SolutionAnnealedAndPickled",
            LengthStatus = "Fixed",
            OuterDiameter = 0,
            WallThickness = 0,
            ContractWeight = 0
        });
    }

    private void RemoveOrderItem(int index)
    {
        orderItemViewModels.RemoveAt(index);
    }

    private async Task SubmitOrder()
    {
        if (orderItemViewModels.Count == 0)
        {
            Snackbar.Add("请至少添加一个订单项次", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(orderNumber) || orderNumber.Length != 11)
        {
            Snackbar.Add("订单号必须为11位字符", Severity.Warning);
            return;
        }

        if (!signDate.HasValue)
        {
            Snackbar.Add("请选择签订日期", Severity.Warning);
            return;
        }

        if (selectedCustomerId == 0)
        {
            Snackbar.Add("请选择客户", Severity.Warning);
            return;
        }

        // 将 ViewModel 转换为 CreateOrderItemRequest
        var items = orderItemViewModels.Select(vm => new CreateOrderItemRequest
        {
            DeliveryDate = vm.DeliveryDate ?? DateTime.Now,
            SettlementMethod = vm.SettlementMethod,
            MaterialName = vm.MaterialName,
            ProductionStandardId = vm.ProductionStandardId,
            DeliveryState = vm.DeliveryState,
            StandardGrade = vm.StandardGrade,
            OuterDiameter = vm.OuterDiameter,
            WallThickness = vm.WallThickness,
            OuterDiameterNegative = 0,
            OuterDiameterPositive = 0,
            WallThicknessNegative = 0,
            WallThicknessPositive = 0,
            ContractWeight = vm.ContractWeight,
            LengthStatus = vm.LengthStatus,
            MinLength = vm.MinLength,
            MaxLength = vm.MaxLength,
            Quantity = vm.Quantity,
            Meters = vm.Meters,
            Remark = vm.Remark
        }).ToList();

        var request = new CreateSalesOrderRequest
        {
            OrderNumber = orderNumber,
            SignDate = signDate.Value,
            CustomerId = selectedCustomerId,
            Items = items
        };

        isSubmitting = true;
        StateHasChanged();

        var result = await OrderService.CreateAsync(request);
        if (result.Success && result.Data != null)
        {
            Snackbar.Add($"订单创建成功！订单号：{result.Data.OrderNumber}", Severity.Success);
            Navigation.NavigateTo("/orders");
        }
        else
        {
            Snackbar.Add(result.Message ?? "创建订单失败", Severity.Error);
        }

        isSubmitting = false;
        StateHasChanged();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/orders");
    }
}