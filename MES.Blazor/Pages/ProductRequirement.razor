@page "/orders/{orderId:int}/requirements"
@page "/orders/{orderId:int}/requirements/edit"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject ProductRequirementService RequirementService
@inject OrderService OrderService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "OrderStaff,OrderDirector,Admin")]

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @if (isLoading)
    {
        <MudProgressCircular Indeterminate Size="Size.Large" Class="d-flex justify-center ma-8" />
    }
    else
    {
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" Color="Color.Primary" />
                        技术要求
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">订单号：@orderNumber</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Text" OnClick="GoBack">返回</MudButton>
                    @if (isEditMode)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAllRequirements" Disabled="@isSubmitting">
                            @if (isSubmitting) { <MudProgressCircular Size="Size.Small" Color="Color.Inherit" /> }
                            else { <span>保存修改</span> }
                        </MudButton>
                    }
                    else
                    {
                        <AuthorizeView Roles="OrderDirector,Admin">
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="EnterEditMode">编辑技术要求</MudButton>
                        </AuthorizeView>
                    }
                </CardHeaderActions>
            </MudCardHeader>

            <MudCardContent>
                @if (!isEditMode)
                {
                    <!-- 查看模式：只读表格 -->
                    <div style="overflow-x: auto;">
                        <MudTable T="ProductRequirementDto" 
                                  Items="@requirements.OrderBy(r => r.Sequence).ToList()" 
                                  Dense="true" 
                                  Hover="true"
                                  Elevation="0">
                            <HeaderContent>
                                <MudTh>项次</MudTh>
                                <MudTh>要求类型</MudTh>
                                <MudTh>化学成分</MudTh>
                                <MudTh>机械性能</MudTh>
                                <MudTh>尺寸公差</MudTh>
                                <MudTh>表面质量</MudTh>
                                <MudTh>无损检测</MudTh>
                                <MudTh>其他要求</MudTh>
                                <MudTh>创建时间</MudTh>
                                <MudTh>更新时间</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Sequence.ToString()</MudTd>
                                <MudTd>@context.RequirementType.ToString()</MudTd>
                                <MudTd>@context.ChemicalComposition</MudTd>
                                <MudTd>@context.MechanicalProperty</MudTd>
                                <MudTd>@context.ToleranceRequirement</MudTd>
                                <MudTd>@context.SurfaceQuality</MudTd>
                                <MudTd>@context.NdtRequirement</MudTd>
                                <MudTd>@context.OtherRequirement</MudTd>
                                <MudTd>@FormatDateTime(context.CreatedTime)</MudTd>
                                <MudTd>@FormatDateTime(context.UpdatedTime)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                }
                else
                {
                    <!-- 编辑模式：每个项次一个卡片，可编辑 -->
                    <MudAlert Severity="Severity.Warning" Class="mb-3">修改后请点击右上角“保存修改”按钮。</MudAlert>
                    @for (int i = 0; i < requirements.Count; i++)
                    {
                        var req = requirements[i];
                        var index = i;
                        <MudCard Class="mb-4" Variant="Variant.Outlined">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1">项次 @req.Sequence</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="RequirementType" Label="要求类型" @bind-Value="req.RequirementType">
                                            <MudSelectItem Value="@RequirementType.Normal">常规</MudSelectItem>
                                            <MudSelectItem Value="@RequirementType.Special">特殊</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="12">
                                        <MudTextField T="string" Label="化学成分要求" @bind-Value="req.ChemicalComposition" Multiline="true" Lines="3" />
                                    </MudItem>
                                    <MudItem xs="12" md="12">
                                        <MudTextField T="string" Label="机械性能要求" @bind-Value="req.MechanicalProperty" Multiline="true" Lines="3" />
                                    </MudItem>
                                    <MudItem xs="12" md="12">
                                        <MudTextField T="string" Label="尺寸公差要求" @bind-Value="req.ToleranceRequirement" Multiline="true" Lines="3" />
                                    </MudItem>
                                    <MudItem xs="12" md="12">
                                        <MudTextField T="string" Label="表面质量要求" @bind-Value="req.SurfaceQuality" Multiline="true" Lines="3" />
                                    </MudItem>
                                    <MudItem xs="12" md="12">
                                        <MudTextField T="string" Label="无损检测要求" @bind-Value="req.NdtRequirement" Multiline="true" Lines="3" />
                                    </MudItem>
                                    <MudItem xs="12" md="12">
                                        <MudTextField T="string" Label="其他要求" @bind-Value="req.OtherRequirement" Multiline="true" Lines="3" />
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>
                    }
                }
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public int orderId { get; set; }
    private bool isEditMode => Navigation.Uri.Contains("/edit");
    private string orderNumber = string.Empty;
    private List<ProductRequirementDto> requirements = new();
    private bool isLoading = true;
    private bool isSubmitting;

    private string FormatDateTime(DateTimeOffset dt)
    {
        return dt == DateTimeOffset.MinValue ? "-" : dt.ToString("yyyy-MM-dd HH:mm");
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        if (orderId <= 0)
        {
            Snackbar.Add("无效的订单ID", Severity.Error);
            isLoading = false;
            return;
        }
        isLoading = true;
        StateHasChanged();
        try
        {
            var orderResult = await OrderService.GetByIdAsync(orderId);
            if (orderResult.Success && orderResult.Data != null)
            {
                orderNumber = orderResult.Data.OrderNumber;
            }
            else
            {
                Snackbar.Add("无法获取订单信息", Severity.Error);
                return;
            }

            var reqResult = await RequirementService.GetByOrderIdAsync(orderId);
            if (reqResult.Success && reqResult.Data != null)
            {
                requirements = reqResult.Data.OrderBy(r => r.Sequence).ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void EnterEditMode() => Navigation.NavigateTo($"/orders/{orderId}/requirements/edit");

    private async Task SaveAllRequirements()
    {
        isSubmitting = true;
        StateHasChanged();
        try
        {
            foreach (var req in requirements)
            {
                var request = new CreateProductRequirementRequest
                {
                    RequirementType = req.RequirementType,
                    ChemicalComposition = req.ChemicalComposition,
                    MechanicalProperty = req.MechanicalProperty,
                    ToleranceRequirement = req.ToleranceRequirement,
                    SurfaceQuality = req.SurfaceQuality,
                    NdtRequirement = req.NdtRequirement,
                    OtherRequirement = req.OtherRequirement
                };
                var result = await RequirementService.CreateOrUpdateAsync(orderId, req.OrderItemId, request);
                if (!result.Success)
                {
                    Snackbar.Add($"保存项次 {req.Sequence} 技术要求失败: {result.Message}", Severity.Error);
                    return;
                }
            }
            Snackbar.Add("所有技术要求保存成功", Severity.Success);
            Navigation.NavigateTo($"/orders/{orderId}/requirements");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void GoBack() => Navigation.NavigateTo($"/orders/{orderId}");
}