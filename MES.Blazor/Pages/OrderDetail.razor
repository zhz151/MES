@page "/orders/{id:int}"
@page "/orders/{id:int}/edit"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Models
@using MES.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject IOrderService OrderService
@inject ICustomerService CustomerService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (isLoading)
    {
        <MudProgressCircular Indeterminate Size="Size.Large" Class="d-flex justify-center ma-8" />
    }
    else if (orderDetail == null)
    {
        <MudAlert Severity="Severity.Error">ЖЉЕЅВЛДцдк</MudAlert>
    }
    else
    {
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" Color="Color.Primary" />
                        ЖЉЕЅЯъЧщ
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        ЖЉЕЅКХЃК@orderDetail.OrderNumber
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Text" OnClick="GoBack">ЗЕЛи</MudButton>
                    @if (isEditMode)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitUpdate" Disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <MudProgressCircular Size="Size.Small" Color="Color.Inherit" />
                            }
                            else
                            {
                                <span>БЃДцаоИФ</span>
                            }
                        </MudButton>
                    }
                    else
                    {
                        <AuthorizeView Roles="OrderDirector,Admin">
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="EnterEditMode">БрМ­</MudButton>
                        </AuthorizeView>
                    }
                </CardHeaderActions>
            </MudCardHeader>

            <MudCardContent>
                <!-- ЖЉЕЅЛљБОаХЯЂ -->
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                    ЛљБОаХЯЂ
                </MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string"
                                      Label="ЖЉЕЅКХ"
                                      @bind-Value="editOrder.OrderNumber"
                                      Disabled="!isEditMode"
                                      HelperText="11ЮЛзжЗћ" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="editOrder.SignDate"
                                       Label="ЧЉЖЉШеЦк"
                                       Disabled="!isEditMode" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <!-- аоИД CS1503: ЪЙгУ T="int?" ЦЅХф editOrder.CustomerId ЕФ int? РраЭ -->
                        <MudSelect T="int?" @bind-Value="editOrder.CustomerId"
                                   Label="ПЭЛЇЕЅЮЛ"
                                   Disabled="!isEditMode">
                            @foreach (var customer in customers)
                            {
                                <MudSelectItem Value="@customer.Id">@customer.CustomerUnit</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" @bind-Value="editOrder.Status"
                                   Label="ЖЉЕЅзДЬЌ"
                                   Disabled="!isEditMode">
                            <MudSelectItem Value="@("Pending")">Д§ДІРэ</MudSelectItem>
                            <MudSelectItem Value="@("Confirmed")">вбШЗШЯ</MudSelectItem>
                            <MudSelectItem Value="@("Processing")">ДІРэжа</MudSelectItem>
                            <MudSelectItem Value="@("Completed")">вбЭъГЩ</MudSelectItem>
                            <MudSelectItem Value="@("Cancelled")">вбШЁЯћ</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <!-- ЖЉЕЅЯюДЮСаБэ -->
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Small" Class="mr-1" />
                    ЖЉЕЅЯюДЮ
                </MudText>

                <MudTable T="OrderItemDto" Items="@(orderDetail.Items ?? new List<OrderItemDto>())" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>ЯюДЮ</MudTh>
                        <MudTh>ЙцИё</MudTh>
                        <MudTh>ХЦКХ</MudTh>
                        <MudTh>Ъ§СП</MudTh>
                        <MudTh>КЯЭЌжиСП(kg)</MudTh>
                        <MudTh>РэЫужиСП(kg)</MudTh>
                        <MudTh>НЛЛѕШеЦк</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Sequence</MudTd>
                        <MudTd>@context.Specification</MudTd>
                        <MudTd>@context.StandardGrade</MudTd>
                        <MudTd>@context.Quantity</MudTd>
                        <MudTd>@context.ContractWeight.ToString("F2")</MudTd>
                        <MudTd>@context.TheoreticalWeight.ToString("F2")</MudTd>
                        <MudTd>@context.DeliveryDate.ToString("yyyy-MM-dd")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }

    private bool isEditMode => Navigation.Uri.Contains("/edit");
    private SalesOrderDetailDto? orderDetail;
    private UpdateSalesOrderRequest editOrder = new();
    private List<CustomerProfileDto> customers = new();
    private bool isLoading = true;
    private bool isSubmitting;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        // МгдиПЭЛЇСаБэ
        var customersResult = await CustomerService.GetPagedAsync(new QueryParams { PageSize = 999 });
        if (customersResult.Success && customersResult.Data != null)
        {
            customers = customersResult.Data.Items;
        }

        // МгдиЖЉЕЅЯъЧщ
        var result = await OrderService.GetByIdAsync(Id);
        if (result.Success && result.Data != null)
        {
            orderDetail = result.Data;
            editOrder = new UpdateSalesOrderRequest
            {
                OrderNumber = orderDetail.OrderNumber,
                SignDate = orderDetail.SignDate,
                CustomerId = orderDetail.CustomerId,
                Status = orderDetail.Status,
                RowVersion = new byte[] { }  // СйЪБеМЮЛЃЌЪЕМЪгІДгКѓЖЫЛёШЁ
            };
        }

        isLoading = false;
        StateHasChanged();
    }

    private void EnterEditMode()
    {
        Navigation.NavigateTo($"/orders/{Id}/edit");
    }

    private async Task SubmitUpdate()
    {
        // бщжЄ RowVersion ВЛЮЊПе
        if (editOrder.RowVersion == null || editOrder.RowVersion.Length == 0)
        {
            Snackbar.Add("Ъ§ОнАцБОаХЯЂШБЪЇЃЌЧыЫЂаТвГУцКѓжиЪд", Severity.Warning);
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        var result = await OrderService.UpdateAsync(Id, editOrder);
        if (result.Success)
        {
            Snackbar.Add("ИќаТГЩЙІ", Severity.Success);
            Navigation.NavigateTo($"/orders/{Id}");
        }
        else
        {
            Snackbar.Add(result.Message ?? "ИќаТЪЇАм", Severity.Error);
        }

        isSubmitting = false;
        StateHasChanged();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/orders");
    }
}