@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h3>生产仪表板</h3>
<p>欢迎使用 MES 系统，您已成功登录。</p>
<AuthorizeView>
    <Authorized>
        <p>当前角色: @string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</p>
    </Authorized>
</AuthorizeView>
