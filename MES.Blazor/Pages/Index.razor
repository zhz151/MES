@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http

<PageTitle>MES System</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="welcome-container">
            <h1>Welcome to MES System</h1>
            <p>You have successfully logged in!</p>
            <div class="api-test">
                <h3>API Connectivity Test</h3>
                <button class="btn btn-info" @onclick="TestApiConnection" disabled="@_isTesting">
                    @if (_isTesting)
                    {
                        <span>Testing...</span>
                    }
                    else
                    {
                        <span>Test API Connection</span>
                    }
                </button>
                
                @if (!string.IsNullOrEmpty(_apiTestResult))
                {
                    <div class="test-result mt-3">
                        <strong>API Response:</strong>
                        <pre>@_apiTestResult</pre>
                    </div>
                }
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="guest-container">
            <h1>MES Manufacturing Execution System</h1>
            <p>Please <a href="/login">log in</a> to access the system.</p>
            
            <div class="api-test">
                <h3>Public API Test</h3>
                <button class="btn btn-outline-info" @onclick="TestPublicApi" disabled="@_isTesting">
                    @if (_isTesting)
                    {
                        <span>Testing Public API...</span>
                    }
                    else
                    {
                        <span>Test Public API Connection</span>
                    }
                </button>
                
                @if (!string.IsNullOrEmpty(_apiTestResult))
                {
                    <div class="test-result mt-3">
                        <strong>API Response:</strong>
                        <pre>@_apiTestResult</pre>
                    </div>
                }
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .welcome-container, .guest-container {
        max-width: 800px;
        margin: 50px auto;
        text-align: center;
    }
    .api-test {
        margin-top: 30px;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background-color: #f8f9fa;
    }
    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        margin: 10px;
    }
    .btn-info {
        background-color: #17a2b8;
        color: white;
    }
    .btn-outline-info {
        background-color: transparent;
        color: #17a2b8;
        border: 1px solid #17a2b8;
    }
    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    .test-result {
        text-align: left;
        background-color: white;
        padding: 15px;
        border-radius: 4px;
        border-left: 4px solid #17a2b8;
    }
    pre {
        white-space: pre-wrap;
        word-break: break-all;
    }
</style>

@code {
    private bool _isTesting = false;
    private string _apiTestResult = string.Empty;

    private async Task TestApiConnection()
    {
        await TestApiEndpoint("api/auth/userinfo");
    }

    private async Task TestPublicApi()
    {
        await TestApiEndpoint("api/auth/health");
    }

    private async Task TestApiEndpoint(string endpoint)
    {
        _isTesting = true;
        _apiTestResult = string.Empty;
        
        try
        {
            var response = await Http.GetAsync(endpoint);
            var content = await response.Content.ReadAsStringAsync();
            
            _apiTestResult = $"Status: {response.StatusCode}\nResponse: {content}";
        }
        catch (Exception ex)
        {
            _apiTestResult = $"Error: {ex.Message}";
        }
        finally
        {
            _isTesting = false;
            StateHasChanged();
        }
    }
}