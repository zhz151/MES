@page "/orders"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Models
@using MES.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject OrderService OrderService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@attribute [Authorize]

<div class="mt-4">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Class="font-weight-bold">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" Color="Color.Primary" />
                    订单管理
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">销售订单列表</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NavigateToCreate">
                    新建订单
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent>
            <!-- 筛选栏 -->
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField T="string"
                                  Label="模糊搜索 - 订单号/客户名称/业务员/最终客户"
                                  Placeholder="输入关键字..."
                                  @bind-Value="searchKeyword"
                                  Immediate="true"
                                  DebounceInterval="500"
                                  OnKeyDown="OnSearchKeyDown"
                                  Clearable="true"
                                  ClearButton="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect T="string" Label="技术要求状态" @bind-Value="selectedTechStatus" OnValueChanged="OnTechStatusChanged">
                        <MudSelectItem Value="@("All")">全部</MudSelectItem>
                        <MudSelectItem Value="@("Edited")">已编辑</MudSelectItem>
                        <MudSelectItem Value="@("NotEdited")">未编辑</MudSelectItem>
                    </MudSelect>

                    <MudSelect T="string" Label="订单状态" @bind-Value="selectedOrderStatus" OnValueChanged="OnOrderStatusChanged">
                        <MudSelectItem Value="@("All")">全部</MudSelectItem>
                        <MudSelectItem Value="@("Pending")">待处理</MudSelectItem>
                        <MudSelectItem Value="@("Confirmed")">已确认</MudSelectItem>
                        <MudSelectItem Value="@("Cancelled")">已取消</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="Search">
                        搜索
                    </MudButton>
                </MudItem>
            </MudGrid>

            <!-- 数据表格 -->
            <MudTable @ref="table"
                      T="SalesOrderListDto"
                      ServerData="OnServerData"
                      Loading="@isLoading"
                      Dense="true"
                      Hover="true"
                      Class="mt-4"
                      Elevation="0"
                      RowsPerPageLabel="每页行数:">
                <ToolBarContent>
                    <MudText Typo="Typo.body2" Class="ml-auto">
                        共 @totalCount 条记录
                    </MudText>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>订单号</MudTh>
                    <MudTh>签订日期</MudTh>
                    <MudTh>业务员</MudTh>
                    <MudTh>客户名称</MudTh>
                    <MudTh>最终客户</MudTh>
                    <MudTh>技术要求</MudTh>
                    <MudTh>状态</MudTh>
                    <MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.OrderNumber</MudTd>
                    <MudTd>@context.SignDate.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>@context.Salesman</MudTd>
                    <MudTd>@context.CustomerName</MudTd>
                    <MudTd>@context.EndCustomer</MudTd>
                    <MudTd>
                        @if (context.HasTechnicalRequirement)
                        {
                            <MudChip Size="Size.Small" Color="Color.Success">已编辑</MudChip>
                        }
                        else
                        {
                            <div class="d-flex align-center">
                                <MudChip Size="Size.Small" Color="Color.Error">未编辑</MudChip>
                                @if (context.FirstOrderItemId.HasValue)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Warning"
                                                   OnClick="() => EditTechnicalRequirement(context.Id, context.FirstOrderItemId.Value)" />
                                }
                            </div>
                        }
                    </MudTd>
                    <MudTd>
                        <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">
                            @GetStatusText(context.Status)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="() => ViewOrder(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="() => EditOrder(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => DeleteOrder(context)" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
</div>

@code {
    private MudTable<SalesOrderListDto>? table;
    private List<SalesOrderListDto> orders = new();
    private bool isLoading = false;
    private string searchKeyword = string.Empty;
    private string selectedTechStatus = "All";
    private string selectedOrderStatus = "All";
    private int totalCount = 0;

    private bool? GetHasTechnicalRequirement() => selectedTechStatus switch
    {
        "Edited" => true,
        "NotEdited" => false,
        _ => null
    };
    
    private List<SalesOrderStatus>? GetOrderStatuses()
    {
        return selectedOrderStatus switch
        {
            "Pending" => new List<SalesOrderStatus> { SalesOrderStatus.Pending },
            "Confirmed" => new List<SalesOrderStatus> { SalesOrderStatus.Confirmed },
            "Cancelled" => new List<SalesOrderStatus> { SalesOrderStatus.Cancelled },
            _ => null
        };
    }

    private async Task<TableData<SalesOrderListDto>> OnServerData(TableState state)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var queryParams = new QueryParams
            {
                PageIndex = state.Page + 1,
                PageSize = state.PageSize,
                Keyword = string.IsNullOrWhiteSpace(searchKeyword) ? null : searchKeyword
            };

            var result = await OrderService.GetPagedAsync(queryParams, GetHasTechnicalRequirement(), GetOrderStatuses());
            
            if (result.Success && result.Data != null)
            {
                orders = result.Data.Items;
                totalCount = result.Data.TotalCount;
                return new TableData<SalesOrderListDto>
                {
                    Items = orders,
                    TotalItems = totalCount
                };
            }
            
            return new TableData<SalesOrderListDto>
            {
                Items = new List<SalesOrderListDto>(),
                TotalItems = 0
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载失败: {ex.Message}");
            Snackbar.Add($"加载失败: {ex.Message}", Severity.Error);
            return new TableData<SalesOrderListDto>
            {
                Items = new List<SalesOrderListDto>(),
                TotalItems = 0
            };
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task Search()
    {
        if (table != null)
            await table.ReloadServerData();
    }

    private void OnSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            _ = Search();
    }
    
    private void OnTechStatusChanged(string value)
    {
        selectedTechStatus = value;
        _ = Search();
    }
    
    private void OnOrderStatusChanged(string value)
    {
        selectedOrderStatus = value;
        _ = Search();
    }

    private void NavigateToCreate() => Navigation.NavigateTo("/orders/create");
    private void ViewOrder(int id) => Navigation.NavigateTo($"/orders/{id}");
    private void EditOrder(int id) => Navigation.NavigateTo($"/orders/{id}/edit");
    
    private void EditTechnicalRequirement(int orderId, int itemId)
    {
        Navigation.NavigateTo($"/orders/{orderId}/requirements/edit");
    }

    private async Task DeleteOrder(SalesOrderListDto order)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"确定要删除订单 \"{order.OrderNumber}\" 吗？\n\n删除后数据将不可恢复！");

        if (confirmed)
        {
            try
            {
                var result = await OrderService.DeleteAsync(order.Id);
                if (result.Success)
                {
                    Snackbar.Add("删除成功", Severity.Success);
                    await Search();
                }
                else
                {
                    Snackbar.Add(result.Message ?? "删除失败", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private Color GetStatusColor(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Pending => Color.Warning,
        SalesOrderStatus.Confirmed => Color.Info,
        SalesOrderStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Pending => "待处理",
        SalesOrderStatus.Confirmed => "已确认",
        SalesOrderStatus.Cancelled => "已取消",
        _ => status.ToString()
    };
}