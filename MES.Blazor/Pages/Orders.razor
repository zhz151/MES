@page "/orders"
@using MES.Blazor.Services
@using MES.Core.DTOs
@using MES.Core.Models
@using MES.Core.Enums
@using Microsoft.AspNetCore.Authorization
@inject OrderService OrderService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Class="font-weight-bold">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" Color="Color.Primary" />
                    订单管理
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">销售订单列表</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NavigateToCreate">
                    新建订单
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>

        <MudCardContent>
            <!-- 搜索栏 -->
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudTextField T="string"
                                  Label="模糊搜索 - 订单号/客户名称"
                                  Placeholder="输入订单号或客户名称进行模糊搜索..."
                                  @bind-Value="searchKeyword"
                                  Immediate="true"
                                  DebounceInterval="500"
                                  OnKeyDown="OnSearchKeyDown"
                                  Clearable="true"
                                  ClearButton="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="Search">
                        搜索
                    </MudButton>
                </MudItem>
            </MudGrid>

            <!-- 数据表格 -->
            <MudTable T="SalesOrderListDto"
                      Items="@orders"
                      TotalItems="@totalCount"
                      Loading="@isLoading"
                      Dense="true"
                      Hover="true"
                      Class="mt-4"
                      Elevation="0"
                      @bind-CurrentPage="currentPage"
                      @bind-RowsPerPage="pageSize"
                      RowsPerPageLabel="每页行数:"
                      OnPageChanged="OnPageChanged"
                      OnRowsPerPageChanged="OnPageSizeChanged">
                <ToolBarContent>
                    <MudText Typo="Typo.body2" Class="ml-auto">
                        共 @totalCount 条记录
                    </MudText>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>订单号</MudTh>
                    <MudTh>签订日期</MudTh>
                    <MudTh>客户名称</MudTh>
                    <MudTh>状态</MudTh>
                    <MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.OrderNumber</MudTd>
                    <MudTd>@context.SignDate.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>@context.CustomerName</MudTd>
                    <MudTd>
                        <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">
                            @GetStatusText(context.Status)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="() => ViewOrder(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="() => EditOrder(context.Id)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => DeleteOrder(context)" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private List<SalesOrderListDto> orders = new();
    private bool isLoading = true;
    private string searchKeyword = string.Empty;
    
    // 分页相关
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var queryParams = new QueryParams
            {
                PageIndex = currentPage,
                PageSize = pageSize,
                Keyword = string.IsNullOrWhiteSpace(searchKeyword) ? null : searchKeyword
            };

            var result = await OrderService.GetPagedAsync(queryParams);
            
            if (result.Success && result.Data != null)
            {
                orders = result.Data.Items;
                totalCount = result.Data.TotalCount;
                Console.WriteLine($"加载成功: 第{currentPage}页, {orders.Count}条, 总数: {totalCount}");
            }
            else
            {
                orders = new List<SalesOrderListDto>();
                totalCount = 0;
                Snackbar.Add(result?.Message ?? "加载失败", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载失败: {ex.Message}");
            Snackbar.Add($"加载失败: {ex.Message}", Severity.Error);
            orders = new List<SalesOrderListDto>();
            totalCount = 0;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task Search()
    {
        currentPage = 1;
        await LoadData();
        
        if (!string.IsNullOrEmpty(searchKeyword))
        {
            Snackbar.Add($"搜索关键字: {searchKeyword}, 找到 {totalCount} 条记录", Severity.Info);
        }
    }

    private void OnSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            _ = Search();
        }
    }

    private async Task OnPageChanged(int page)
    {
        if (currentPage != page)
        {
            currentPage = page;
            await LoadData();
        }
    }

    private async Task OnPageSizeChanged(int size)
    {
        if (pageSize != size)
        {
            pageSize = size;
            currentPage = 1;
            await LoadData();
        }
    }

    private void NavigateToCreate() => Navigation.NavigateTo("/orders/create");
    private void ViewOrder(int id) => Navigation.NavigateTo($"/orders/{id}");
    private void EditOrder(int id) => Navigation.NavigateTo($"/orders/{id}/edit");

    private async Task DeleteOrder(SalesOrderListDto order)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"确定要删除订单 \"{order.OrderNumber}\" 吗？\n\n删除后数据将不可恢复！");

        if (confirmed)
        {
            try
            {
                var result = await OrderService.DeleteAsync(order.Id);
                if (result.Success)
                {
                    Snackbar.Add("删除成功", Severity.Success);
                    await LoadData();
                }
                else
                {
                    Snackbar.Add(result.Message ?? "删除失败", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除失败: {ex.Message}", Severity.Error);
            }
        }
    }

    private Color GetStatusColor(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Pending => Color.Warning,
        SalesOrderStatus.Confirmed => Color.Info,
        SalesOrderStatus.Processing => Color.Primary,
        SalesOrderStatus.Completed => Color.Success,
        SalesOrderStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(SalesOrderStatus status) => status switch
    {
        SalesOrderStatus.Pending => "待处理",
        SalesOrderStatus.Confirmed => "已确认",
        SalesOrderStatus.Processing => "处理中",
        SalesOrderStatus.Completed => "已完成",
        SalesOrderStatus.Cancelled => "已取消",
        _ => status.ToString()
    };
}