@page "/login"
@using MES.TestLogin.Models
@using MES.TestLogin.Services
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<div class="login-container">
    <h3>MES System Login - Test</h3>

    <EditForm Model="_loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label for="email">Email:</label>
            <InputText @bind-Value="_loginModel.Email" id="email" class="form-control" />
            <ValidationMessage For="() => _loginModel.Email" />
        </div>

        <div class="form-group">
            <label for="password">Password:</label>
            <InputText @bind-Value="_loginModel.Password" id="password" type="password" class="form-control"/>
            <ValidationMessage For="() => _loginModel.Password" />
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_isLoading">
            @if (_isLoading)
            {
                <span>Logging in...</span>
            }
            else
            {
                <span>Login</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger mt-3">
                @_errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success mt-3">
                @_successMessage
            </div>
        }
    </EditForm>

    <div class="test-info mt-3">
        <h5>Test Account Information:</h5>
        <p><strong>Email:</strong> admin@mes.com</p>
        <p><strong>Password:</strong> Admin@123456</p>
        <p><strong>API Endpoint:</strong> https://localhost:5001</p>
    </div>

    <div class="api-test mt-4">
        <button class="btn btn-outline-secondary" @onclick="TestApiConnection" disabled="@_isTestingApi">
            @if (_isTestingApi)
            {
                <span>Testing API...</span>
            }
            else
            {
                <span>Test API Connection</span>
            }
        </button>
        
        @if (!string.IsNullOrEmpty(_apiTestResult))
        {
            <div class="test-result mt-3">
                <strong>API Response:</strong>
                <pre>@_apiTestResult</pre>
            </div>
        }
    </div>
</div>

<style>
    .login-container {
        max-width: 500px;
        margin: 50px auto;
        padding: 30px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background-color: #f9f9f9;
    }
    .form-group {
        margin-bottom: 20px;
    }
    label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
    }
    .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 14px;
    }
    .btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 4px;
        font-size: 14px;
        cursor: pointer;
        margin-bottom: 10px;
    }
    .btn-primary {
        background-color: #007bff;
        color: white;
    }
    .btn-outline-secondary {
        background-color: transparent;
        color: #6c757d;
        border: 1px solid #6c757d;
    }
    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    .alert {
        padding: 10px;
        border-radius: 4px;
        margin-bottom: 10px;
    }
    .alert-danger {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    .test-info {
        background-color: #e9ecef;
        padding: 15px;
        border-radius: 4px;
        margin-top: 20px;
    }
    .test-info h5 {
        margin-top: 0;
        color: #495057;
    }
    .api-test {
        margin-top: 20px;
    }
    .test-result {
        background-color: white;
        padding: 15px;
        border-radius: 4px;
        border-left: 4px solid #17a2b8;
        font-size: 12px;
    }
    pre {
        white-space: pre-wrap;
        word-break: break-all;
        margin: 0;
    }
</style>

@code {
    private LoginModel _loginModel = new();
    private bool _isLoading = false;
    private bool _isTestingApi = false;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private string _apiTestResult = string.Empty;

    protected override void OnInitialized()
    {
        Console.WriteLine("Login page initialized");
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        _successMessage = string.Empty;

        try
        {
            Console.WriteLine($"Attempting login for email: {_loginModel.Email}");
            var result = await AuthService.LoginAsync(_loginModel);
            
            if (result != null && !string.IsNullOrEmpty(result.Token))
            {
                Console.WriteLine("Login successful! Token received: " + result.Token.Substring(0, 20) + "...");
                
                if (AuthenticationStateProvider is CustomAuthenticationStateProvider customProvider)
                {
                    await customProvider.MarkUserAsAuthenticated(result.Token);
                }
                
                _successMessage = $"Login successful! Welcome {result.Email}";
                _successMessage += $"\nPermissions: {result.Permissions.Count}";
                
                // Navigate to home after a short delay
                await Task.Delay(2000);
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = "Login failed. Please check your credentials and ensure the API is running.";
                Console.WriteLine("Login failed - null result or empty token");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Login error: {ex.Message}";
            Console.WriteLine($"Login exception: {ex}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task TestApiConnection()
    {
        _isTestingApi = true;
        _apiTestResult = string.Empty;
        
        try
        {
            Console.WriteLine("Testing API connection...");
            var response = await Http.GetAsync("api/auth/health");
            var content = await response.Content.ReadAsStringAsync();
            
            _apiTestResult = $"Status: {response.StatusCode}\nResponse: {content}";
            Console.WriteLine("API test result: " + _apiTestResult);
        }
        catch (Exception ex)
        {
            _apiTestResult = $"Error: {ex.Message}";
            Console.WriteLine("API test error: " + ex.Message);
        }
        finally
        {
            _isTestingApi = false;
            StateHasChanged();
        }
    }
}